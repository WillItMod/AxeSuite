server=1
txindex=0

# Pruning: disabled by default (archival).
prune=0

# Ports
port=${BCH_P2P_PORT}
rpcport=${BCH_RPC_PORT}

# RPC (do NOT publish the RPC port to the host)
rpcuser=${RPC_USER}
rpcpassword=${RPC_PASSWORD}
rpcbind=0.0.0.0
rpcallowip=0.0.0.0/0

# ZMQ (for pool notifications)
zmqpubhashblock=tcp://0.0.0.0:${BCH_ZMQ_HASHBLOCK_PORT}

